@model PassGuard.Models.ViewModels.AccessViewModel

@{
    ViewData["Title"] = "Add Access";
}

<h2>Add Access</h2>

<form asp-action="Create" method="post">
    @if (User.IsInRole("HomeOwner"))
    {
        <div class="alert alert-info">This pass will be linked to the home assigned to your account.</div>
    }

    <div class="mb-3">
        <label asp-for="EstateName" class="form-label">Estate Name</label>
        <input asp-for="EstateName" class="form-control" readonly="@(User.IsInRole("HomeOwner"))" />
    </div>

    <div class="mb-3">
        <label asp-for="OwnerUserId" class="form-label">Owner User Id</label>
        <input asp-for="OwnerUserId" class="form-control" readonly="@(User.IsInRole("HomeOwner"))" />
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label">Home Address</label>
        <input asp-for="Address" class="form-control" readonly="@(User.IsInRole("HomeOwner"))" />
    </div>

    <hr />

    <div class="mb-3">
        <label asp-for="VisitorFullName" class="form-label">Visitor Name</label>
        <input asp-for="VisitorFullName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="VisitorPhone" class="form-label">Visitor Phone</label>
        <input asp-for="VisitorPhone" class="form-control" />
    </div>

    <p>Status and CheckIn are generated automatically on first create.</p>

    <button type="submit" class="btn btn-success">Save</button>
</form>
