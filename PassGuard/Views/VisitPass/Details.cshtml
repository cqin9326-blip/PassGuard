@model PassGuard.Models.VisitPass

@{
    ViewData["Title"] = "Access Details";
}

<h2>Access Details</h2>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (TempData["NewPassCode"] is string newPassCode)
{
    <div class="alert alert-warning">
        <strong>Pass Code:</strong> <code>@newPassCode</code><br />
        Keep this code now. It is only shown once.
    </div>
}

<p><strong>Visitor Name:</strong> @Model.Visitor.FullName</p>
<p><strong>Visitor Phone:</strong> @Model.Visitor.Phone</p>
<p><strong>Estate Name:</strong> @Model.Home.Estate.EstateName</p>
<p><strong>Owner User Id:</strong> @Model.Home.OwnerUserId</p>
<p><strong>Home Address:</strong> @Model.Home.Address</p>

<hr />

<h4>VisitPass Info</h4>
<p><strong>Status:</strong> @Model.Status</p>
<p><strong>Created At:</strong> @Model.CreatedAt</p>
<p><strong>Expires At:</strong> @Model.ExpiresAt</p>

@if ((User.IsInRole("Admin") || User.IsInRole("HomeOwner")) && Model.Status == PassGuard.Models.PassStatuses.Active)
{
    <form asp-action="Revoke" asp-route-id="@Model.VisitPassId" method="post" class="mb-3">
        <button type="submit" class="btn btn-outline-danger btn-sm">Revoke Pass</button>
    </form>
}

@if (User.IsInRole("Admin") || User.IsInRole("Security"))
{
    <p>
        <a asp-action="Verify" class="btn btn-outline-success btn-sm">Open Verification Screen</a>
    </p>
}

<hr />

<h4>Check-In Info</h4>



@if (Model.GateCheckIn != null)
{
    <p><strong>Result:</strong> @Model.GateCheckIn.Result</p>
    <p><strong>Time:</strong> @Model.GateCheckIn.CheckInTime</p>
    <p><strong>Security User Id:</strong> @Model.GateCheckIn.SecurityUserId</p>
    <p><strong>Note:</strong> @Model.GateCheckIn.Note</p>
    <p>
        <a asp-controller="GateCheckIn" asp-action="Edit" asp-route-id="@Model.GateCheckIn.GateCheckInId">Edit Check-In</a> |
        <a asp-controller="GateCheckIn" asp-action="Delete" asp-route-id="@Model.GateCheckIn.GateCheckInId">Delete Check-In</a>
    </p>
}
else
{
    <p>No check-in records found.</p>

    @if (User.IsInRole("Admin") || User.IsInRole("Security"))
    {
        <p>
            <a asp-controller="GateCheckIn" asp-action="Create" asp-route-visitPassId="@Model.VisitPassId">Record Check-In</a>
        </p>
    }
}
