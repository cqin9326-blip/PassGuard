@model PassGuard.Models.GateCheckIn

@{
    ViewData["Title"] = "Create Check-In";
}

<h2>Create Check-In</h2>

<form asp-action="Create" method="post">
    <input asp-for="VisitPassId" type="hidden" value="@ViewBag.VisitPassId" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Result" class="form-label">Result</label>
        <select asp-for="Result" class="form-control">
            <option value="Approved">Approved</option>
            <option value="Denied">Denied</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="CheckInTime" class="form-label">Check-In Time</label>
        <input asp-for="CheckInTime" type="datetime-local" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Security Officer</label>
        <input asp-for="SecurityUserId" type="hidden" value="@ViewBag.SecurityUserId" />
        <input class="form-control" value="@ViewBag.SecurityUserName" readonly />
    </div>

    <div class="mb-3">
        <label asp-for="Note" class="form-label">Notes</label>
        <input asp-for="Note" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Create</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
