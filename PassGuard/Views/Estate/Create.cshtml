@model PassGuard.Models.ViewModels.EstateFormViewModel

@{
    ViewData["Title"] = "Add Estate";
}

<h2>Add Estate</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="EstateName" class="form-label"></label>
        <input asp-for="EstateName" class="form-control" />
        <span asp-validation-for="EstateName" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
