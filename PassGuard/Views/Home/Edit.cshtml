@model PassGuard.Models.ViewModels.PropertyViewModel

@{
    ViewData["Title"] = "Edit Property";
}

<h2>Edit Property</h2>

<form asp-action="Edit" method="post">
    <input asp-for="HomeId" type="hidden" />

    <div class="mb-3">
        <label asp-for="EstateName" class="form-label">Estate Name</label>
        <input asp-for="EstateName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="OwnerUserId" class="form-label">Owner User Id</label>
        <select asp-for="OwnerUserId" asp-items="ViewBag.HomeOwnerUsers" class="form-control">
            <option value="">Select homeowner</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label">Home Address</label>
        <input asp-for="Address" class="form-control" />
    </div>

    <hr />

    <h4>Visitor Info</h4>

    <div class="mb-3">
        <label asp-for="VisitorFullName" class="form-label">Visitor Name</label>
        <input asp-for="VisitorFullName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="VisitorPhone" class="form-label">Visitor Phone</label>
        <input asp-for="VisitorPhone" class="form-control" />
    </div>

    <button type="submit" class="btn btn-warning">Update</button>
</form>
