@model PassGuard.Models.ViewModels.UserRoleEditViewModel

@{
    ViewData["Title"] = "Edit User Role";
}

<h2>Edit User Role</h2>

<form asp-action="EditRole" method="post">
    <input asp-for="UserId" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label class="form-label">Full Name</label>
        <input class="form-control" value="@Model.FullName" disabled />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input class="form-control" value="@Model.Email" disabled />
    </div>

    <div class="mb-3">
        <label asp-for="RoleName" class="form-label">Role</label>
        <select asp-for="RoleName" class="form-control">
            @foreach (var role in Model.AvailableRoles)
            {
                <option value="@role">@role</option>
            }
        </select>
        <span asp-validation-for="RoleName" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save Role</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
